{
<* if {{ is_dark_mode }} *>
    "mode": "dark",
    "bg": "#2d2d2d",
    "bg_raised": "#393939",
    "ink": "#cccccc",
    "ink_body": "rgba(204, 204, 204, 0.7)",
    "ink_muted": "rgba(204, 204, 204, 0.5)",
    "accent": "#6699cc",
    "accent_dim": "#515151",
    "error": "#f2777a"
<* else *>
    "mode": "light",
    "bg": "#fdf6e3",
    "bg_raised": "#eee8d5",
    "ink": "#657b83",
    "ink_body": "rgba(101, 123, 131, 0.7)",
    "ink_muted": "rgba(101, 123, 131, 0.5)",
    "accent": "#268bd2",
    "accent_dim": "#93a1a1",
    "error": "#dc322f"
<* endif *>
}
