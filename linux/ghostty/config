# Shell
command = /usr/bin/fish

# Font — match foot
font-family = monospace
font-size = 13

# Theme — auto-switches with system appearance
theme = dark:tomorrow-night-eighties,light:solarized-light-custom

# Window
window-theme = ghostty
window-decoration = auto
gtk-titlebar-style = native
window-padding-x = 4
window-padding-y = 4

# Scrollback
scrollback-limit = 10000

# Mouse
mouse-hide-while-typing = true

# Performance
bold-is-bright = false

# Keybinds — Alt is the Linux equivalent of macOS Cmd
keybind = alt+d=new_split:right
keybind = alt+shift+d=new_split:down
keybind = alt+w=close_surface

# Shell integration
shell-integration = fish
shell-integration-features = cursor,sudo,title
